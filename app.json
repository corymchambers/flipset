{
  "expo": {
    "name": "Flipset",
    "slug": "flipset",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "flipset",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.corychambers.flipset",
      "buildNumber": "10",
      "appleTeamId": "D8DX35HW6N",
      "deploymentTarget": "15.5",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.corychambers.flipset",
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      "expo-speech-recognition",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0a0a",
          "image": "./assets/splash-icon.png",
          "imageWidth": 1200
        }
      ],
      [
        "expo-signed",
        {
          "store_file": {
            "key": "FLIPSET_UPLOAD_STORE_FILE",
            "value": "release.keystore"
          },
          "key_alias": {
            "key": "FLIPSET_UPLOAD_KEY_ALIAS",
            "value": "flipset"
          },
          "store_password": {
            "key": "FLIPSET_UPLOAD_STORE_PASSWORD",
            "value": ""
          },
          "key_password": {
            "key": "FLIPSET_UPLOAD_KEY_PASSWORD",
            "value": ""
          },
          "keystorePath": "."
        }
      ]
    ]
  }
}
